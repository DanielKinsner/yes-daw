{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "ci",
      "displayName": "CI (Ninja, Release)",
      "description": "The one invocation every machine and the cloud share, byte-identical and path-free.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    }
  ],
  "buildPresets": [
    { "name": "ci", "configurePreset": "ci" }
  ],
  "testPresets": [
    { "name": "ci", "configurePreset": "ci", "output": { "outputOnFailure": true } }
  ]
}
